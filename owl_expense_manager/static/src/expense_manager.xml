<templates>
    <t t-name="owl_expense_manager.expense_manager">
        <div class="o_expense_manager">

            <!-- Header -->
            <div class="o_expense_header">
                <div>
                    <h3>Expenses</h3>
                    <p class="text-muted mb-0">
                        Track and manage expenses
                    </p>
                </div>
            </div>

            <!-- Expense Form -->
            <div class="o_expense_form">
                <div class="o_field">
                    <label>Title</label>
                    <input
                        type="text"
                        class="form-control"
                        placeholder="Enter expense title"
                        t-model="this.state.form.title"
                    />
                </div>

                <div class="o_field">
                    <label>Amount</label>
                    <input
                        type="number"
                        class="form-control"
                        placeholder="0.00"
                        t-model.number="this.state.form.amount"
                    />
                </div>

                <div class="o_field">
                    <label>Category</label>
                    <select
                        class="form-select"
                        t-model="this.state.form.category"
                    >
                        <option value="">Select Category</option>
                        <option value="Food">Food</option>
                        <option value="Travel">Travel</option>
                        <option value="Shopping">Shopping</option>
                        <option value="Bills">Bills</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="o_form_action">
                    <button
                        class="btn btn-primary"
                        t-on-click="this.addExpense"
                    >
                        Add Expense
                    </button>
                </div>

            </div>

            <div class="o_expense_filter">
                <h2>Filters</h2>
                <div class="o_expense_form">
                    <div class="o_field">
                        <label>Title</label>
                        <input
                            type="text"
                            class="form-control"
                            placeholder="Search expense"
                            t-model.proxy="this.state.filters.query"
                        />
                    </div>
                    <div class="o_field">
                        <label>Category</label>
                        <select
                            class="form-select"
                            t-model.proxy="this.state.filters.category"
                        >
                            <option value="">Select Category</option>
                            <option value="all">All</option>
                            <option value="Food">Food</option>
                            <option value="Travel">Travel</option>
                            <option value="Shopping">Shopping</option>
                            <option value="Bills">Bills</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Empty State -->
            <div
                t-if="!this.state.expenses.length"
                class="o_expense_empty"
            >
                No expenses added yet.
            </div>

            <!-- Expense List -->
            <div
                t-else=""
                class="o_expense_list">
                <ExpenseItem
                    t-foreach="this.filteredExpenses()"
                    t-as="expense"
                    t-key="expense.id"
                    expense="expense"
                    onDelete.bind="this.deleteExpense"
                />
            </div>

        </div>
    </t>
</templates>